                      00368 
                      00369 ;BUTTON HANDLING:
                      00370 ;1.CHECK_BUTTONS:Reads all three buttons.  
                      00371 ;Each button uses a lock bit so only one event
                      00372 ;fires per press (no auto-repeat).
                      00373 ;Sets BTN_xxx_FLG on falling edge.   
00DD                  00374 CHECK_BUTTONS:
00DD   1283 1303      00375     BANKSEL BTN_PORT
                      00376     
                      00377 ;SELECT button: (RB4/active low/one event per press).
00DF   1A06           00378     BTFSC   BTN_PORT, BTN_SEL
00E0   28E6           00379     GOTO    SEL_RELEASED
00E1   1838           00380     BTFSC   BTN_SEL_LOCK      ; already locked? -> no new event
00E2   28E7           00381     GOTO    CHK_ENTER
00E3   14A4           00382     BSF     BTN_SEL_FLG       ; new press
00E4   1438           00383     BSF     BTN_SEL_LOCK
00E5   28E7           00384     GOTO    CHK_ENTER
00E6                  00385 SEL_RELEASED:
00E6   1038           00386     BCF     BTN_SEL_LOCK      ; unlock when released
                      00387 
                      00388 ;ENTER button: (RB5/active low/one event per press).
00E7                  00389 CHK_ENTER:
00E7   1A86           00390     BTFSC   BTN_PORT, BTN_ENT
00E8   28EE           00391     GOTO    ENT_RELEASED
00E9   18B8           00392     BTFSC   BTN_ENT_LOCK
00EA   28EF           00393     GOTO    CHK_BACK
00EB   1524           00394     BSF     BTN_ENT_FLG
00EC   14B8           00395     BSF     BTN_ENT_LOCK
00ED   28EF           00396     GOTO    CHK_BACK
00EE                  00397 ENT_RELEASED:
00EE   10B8           00398     BCF     BTN_ENT_LOCK
                      00399 
                      00400 ;BACK button: (RB6/active low/one event per press).
00EF                  00401 CHK_BACK:
