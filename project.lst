0000   2811           00044     goto START_INITIALIZE  ; reset vector --> initialization
0004                  00045     org 0x04               ; interrupt vector
                      00046     
                      00047     ;ISR - Timer0 Overflow Handler \  Fires every ~1ms.
0004                  00048 ISR:
0004   00A0           00049     MOVWF W_TEMP                
0005   0E03           00050     SWAPF STATUS, W       ; save W
0006   00A1           00051     MOVWF STATUS_TEMP     ; save STATUS (swap avoids affecting flags)
                      00052     
0007   1D0B           00053     BTFSS INTCON,T0IF     ; was this a Timer0 interrupt?
0008   280C           00054     GOTO  ISR_EXIT        ; no  -> skip
0009   110B           00055     BCF   INTCON, T0IF    ; yes -> clear flag
                      00056     
000A   0AA7           00057     INCF  TICK_COUNT,F    ; count the tick
000B   1424           00058     BSF   TICK_FLG        ; signal main loop
000C                  00059 ISR_EXIT:
000C   0E21           00060     SWAPF STATUS_TEMP, W  ; restore STATUS
000D   0083           00061     MOVWF STATUS              
000E   0EA0           00062     SWAPF W_TEMP, F       ; restore W (swap trick: no flag change)
000F   0E20           00063     SWAPF W_TEMP, W          
0010   0009           00064     RETFIE                  
                      00065       
0011                  00066 START_INITIALIZE:
0011   1683 1303      00067     BANKSEL TRIS_LCD
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
0013   0188           00068     CLRF    TRIS_LCD           ;LCD port: all outputs
                      00069     ;Timer0 setup
0014   202C           00070     CALL    INIT_TIMER0           
                      00071     ;Button pins : inputs
0015   1683 1303      00072     BANKSEL BTN_TRIS
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
0017   1606           00073     BSF     BTN_TRIS, BTN_SEL   
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
0018   1686           00074     BSF     BTN_TRIS, BTN_ENT  
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
0019   1706           00075     BSF     BTN_TRIS, BTN_BCK 
                      00076     ;SPI (MSSP) + LCD init    
001A   2038           00077     call    INIT_MSSP
001B   2041           00078     call    INITIALIZE_LCD
001C   20CA           00079     call    CLEAR_SCREEN
                      00080     ;Variable reset 
001D   30FF           00081     MOVLW   0xFF
001E   00A3           00082     MOVWF   SYSTEM_MODE        ;start in main-menu state 
001F   01A2           00083     CLRF    CURRENT_MENU       ;cursor on first item (Clock)
0020   01A4           00084     CLRF    FLAGS
0021   01B8           00085     CLRF    BTN_LOCK
                      00086     ;Clock default: 12:00:00
0022   300C           00087     MOVLW   d'12'
0023   00AA           00088     MOVWF   CLK_HOUR
0024   01A9           00089     CLRF    CLK_MIN
0025   01A8           00090     CLRF    CLK_SEC
0026   01B7           00091     CLRF    COLON_STATE
                      00092     ;HSLM default position
