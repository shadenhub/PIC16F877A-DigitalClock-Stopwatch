                      00327   
                      00328 ;SET_LCD_ROW   W = row (0-5)
                      00329 ;Positions cursor to the start of the requested page row.  
00C2                  00330 SET_LCD_ROW:   
00C2   00A0           00331    MOVWF   W_TEMP              
