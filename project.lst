00AD                  00300 WAIT_SPI_CMD:
00AD   1283           00301     BCF     STATUS, RP0       
00AE   1D8C           00302     BTFSS   PIR1, SSPIF       ;Wait for transfer complete
00AF   28AD           00303     GOTO    WAIT_SPI_CMD      
00B0   118C           00304     BCF     PIR1, SSPIF       
