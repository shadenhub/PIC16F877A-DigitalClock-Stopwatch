0027   01B6           00093     CLRF    HSLM_TICK
0028   303C           00094     MOVLW   D'60'
0029   00B5           00095     MOVWF   HSLM_POS
                      00096     ;Draw main menu and enter loop 
002A   211B           00097     CALL    SHOW_MAIN_MENU
002B   2854           00098     GOTO    MAIN
                      00099 
                      00100     ;INIT_TIMER0:Prescaler 1:256, internal clock. 
                      00101     ;~1ms overflow at 4MHz.
                      00102     ;Enables GIE + T0IE.
002C                  00103 INIT_TIMER0:
002C   1683 1303      00104     BANKSEL OPTION_REG           
002E   3007           00105     MOVLW   b'00000111' ; TOCS=0 (internal), PS=111 (1:256) 
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
002F   0081           00106     MOVWF   OPTION_REG
0030   1283 1303      00107     BANKSEL TMR0
0032   0181           00108     CLRF    TMR0
0033   1283 1303      00109     BANKSEL INTCON
0035   30E0           00110     MOVLW   b'11100000' ; GIE=1, PEIE=1, T0IE=1
0036   008B           00111     MOVWF   INTCON    
0037   0008           00112     RETURN 
                      00113     
                      00114     ;INIT_MSSP --> Configures hardware SPI: Master, Fosc/4, CKP=0 (idle low), CKE=0.
                      00115     ;RC3=SCLK (output), RC5=SDIN (output).    
0038                  00116 INIT_MSSP:     
0038   1683           00117     BSF     STATUS,RP0   ; Bank1        
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
0039   1187           00118     BCF     TRISC, 3     ; RC3 = SCLK  OUTPUT 
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
003A   1287           00119     BCF     TRISC, 5     ; RC5 = SDIN  OUTPUT
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
003B   0194           00120     CLRF    SSPSTAT      ; SMP(bit7)=0 (sample middle) , CKE(bit6)=0 (rising edge)
003C   1283           00121     BCF     STATUS,RP0   ; Bank0
                      00122     ;SSPM3:SSPM0(bit3-0)= 0000 (SPI Master Fosc/4)
                      00123     ;SSPEN(bit5)=1 MSSP is ON / CKP(bit4)=0 LOW to HIGH
003D   3020           00124     MOVLW   B'00100000'    
003E   0094           00125     MOVWF   SSPCON
003F   118C           00126     BCF     PIR1 , SSPIF  ; clear any stale SPI flag    
0040   0008           00127     RETURN
                      00128           
                      00129     ;  INITIALIZE_LCD : Hardware reset pulse, then extended-instruction-set configuration.              
                              
0041                  00130 INITIALIZE_LCD:
0041   1008           00131     BCF     PORT_LCD, LCD_RST  ; pull RST low 
0042   0000           00132     NOP
0043   0000           00133     NOP
0044   1408           00134     BSF     PORT_LCD, LCD_RST  ; release RST
                      00135     
0045   1003           00136     BCF     STATUS, C          ; C=0 --- command mode
0046   3021           00137     MOVLW   0x21               ; extended instruction mode  
0047   20A9           00138     CALL    SEND_CMD 
0048   30BF           00139     MOVLW   0xBF               ; set VOP    
0049   20A9           00140     CALL    SEND_CMD 
