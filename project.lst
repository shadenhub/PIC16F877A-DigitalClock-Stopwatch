00CE   3006           00349     MOVLW   D'6'        ; 6 pages
00CF   00A5           00350     MOVWF   CLEAR_CTR_HI
00D0                  00351 CLEAR_PAGE_LOOP:
00D0   3054           00352     MOVLW   D'84'       ; 84 columns per page
