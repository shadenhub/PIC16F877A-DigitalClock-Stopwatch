00B2   1508           00306     BSF     PORT_LCD, LCD_CE  ;Disable Chip Select (Pull CE High)
00B3   0008           00307     RETURN
                      00308      
00B4                  00309 SEND_DATA:
00B4   1283           00310     BCF     STATUS, RP0          
00B5   1488           00311     BSF     PORT_LCD, LCD_DC  ;Data Mode DC=1  
00B6   1108           00312     BCF     PORT_LCD, LCD_CE  ;Enable Chip Select (Pull CE Low)
00B7   0093           00313     MOVWF   SSPBUF            ;Start ISP transmission  
00B8                  00314 WAIT_SPI_DATA:
00B8   1283           00315     BCF     STATUS, RP0       
00B9   1D8C           00316     BTFSS   PIR1, SSPIF       ;Wait for transfer complete
00BA   28B8           00317     GOTO    WAIT_SPI_DATA     
00BB   118C           00318     BCF     PIR1, SSPIF       
00BC   1283           00319     BCF     STATUS, RP0       
00BD   1508           00320     BSF     PORT_LCD, LCD_CE  ;Disable Chip Select (Pull CE High)
00BE   0008           00321     RETURN
                      00322     
00BF                  00323 SEND_INV_DATA:
