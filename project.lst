004A   3004           00141     MOVLW   0x04               ; temperature coefficient  
004B   20A9           00142     CALL    SEND_CMD
004C   3014           00143     MOVLW   0x14               ; bias system (1:48) 
004D   20A9           00144     CALL    SEND_CMD
004E   3020           00145     MOVLW   0x20               ; normal instruction mode  
004F   20A9           00146     CALL    SEND_CMD 
0050   300C           00147     MOVLW   0x0C               ;display on, normal mode 
0051   20A9           00148     CALL    SEND_CMD
                      00149     
0052   1283           00150     BCF     STATUS,RP0 
0053   0008           00151     RETURN 
                      00152     
                      00153     
                      00154     ;MAIN LOOP : Waits for the TICK_FLG set by the ISR, then:
                      00155     ;1. Runs per-tick math (HSLM animation + 1-second counters)
                      00156     ;2. Polls buttons and routes to actions 
0054                  00157 MAIN: 
0054   1C24           00158     BTFSS TICK_FLG            ; wait for ISR tick
0055   2854           00159     GOTO  MAIN
0056   1024           00160     BCF   TICK_FLG            ; acknowledge tick
                      00161      
0057   205B           00162     CALL  StartCounter        ; update timers / displays
0058   205A           00163     CALL  RUN_POLL_INTERFACES ; check buttons
0059   2854           00164     GOTO  MAIN
                      00165     
005A                  00166 RUN_POLL_INTERFACES:
005A   28F8           00167     GOTO    POLL_INTERFACES 
                      00168     
                      00169     ;TICK PROCESSING - StartCounter : Called every tick (~1ms).
                      00170     ;Always runs HSLM animation sub-tick.
                      00171     ;Every 77 ticks: updates clock, optionally updates stopwatch,
                      00172     ;then refreshes the active screen.        
005B                  00173 StartCounter:
005B   168B           00174    BSF     INTCON, T0IE   ; ensure Timer0 interrupt is enabled
005C   206F           00175    CALL    HSLM_MATH      ; animation runs every tick
                      00176    
005D   304D           00177    MOVLW   d'77'          ; 77 ticks ~ 1 second
005E   0227           00178    SUBWF   TICK_COUNT, W
005F   1D03           00179    BTFSS   STATUS, Z
0060   0008           00180    RETURN                 ; not a second yet
                      00181    
0061   01A7           00182    CLRF    TICK_COUNT     ; reset accumulator
                      00183    
0062   2081           00184    CALL    CLOCK_MATH     ; clock always runs
0063   1F24           00185    BTFSS   SW_RUNNING     ; stopwatch runs only if SW_RUNNING = 1
0064   2866           00186    GOTO    REFRESH_ACTIVE_SCREEN
0065   2096           00187    CALL    STOPWATCH_MATH
                      00188    
0066                  00189 REFRESH_ACTIVE_SCREEN:
0066   0823           00190    MOVF    SYSTEM_MODE, W
0067   3A00           00191    XORLW   0x00
0068   1903           00192    BTFSC   STATUS, Z
0069   2157           00193    CALL    UpdateClock    ; refresh clock display
