                      00566         LIST
                      00002 #define PORT_LCD  PORTD
                      00003 #define TRIS_LCD  TRISD 
                      00004 #define LCD_RST   0    ; RD0 - Reset (active low)
                      00005 #define LCD_DC    1    ; RD1 - Data/Command select
                      00006 #define LCD_CE    2    ; RD2 - Chip Enable (active low)
                      00007 #define BTN_PORT  PORTB
                      00008 #define BTN_TRIS  TRISB 
                      00009 ; Push Buttons (active low) 
                      00010 #define BTN_SEL   4
                      00011 #define BTN_ENT   5
                      00012 #define BTN_BCK   6
                      00013   CBLOCK 0x20
  00000020            00014 W_TEMP,STATUS_TEMP,CURRENT_MENU,SYSTEM_MODE,FLAGS,CLEAR_CTR_HI,CLEAR_CTR_LO
                      00015   endc
                      00016   CBLOCK 0x27
  00000027            00017 TICK_COUNT,CLK_SEC,CLK_MIN,CLK_HOUR,SW_MS,SW_SEC,SW_MI,SW_HOUR,Index,Digit,FONT_TEMP,First_Digit,Second_
                            Digit,clkTickFlag,HSLM_POS,HSLM_TICK,COLON_STATE,BTN_LOCK
                      00018   endc
                      00019 #define TICK_FLG     FLAGS,0      ; set by ISR each Timer0 overflow
                      00020 #define BTN_SEL_FLG  FLAGS,1      ; SELECT pressed this tick
                      00021 #define BTN_ENT_FLG  FLAGS,2      ; ENTER  pressed this tick
                      00022 #define BTN_BCK_FLG  FLAGS,3      ; BACK   pressed this tick
                      00023 #define CLK_UPD_FLG  FLAGS,4      ; (reserved) clock update pending
                      00024 #define SW_UPD_FLG   FLAGS,5      ; (reserved) stopwatch update pending
                      00025 #define SW_RUNNING   FLAGS,6      ; 1 = stopwatch is counting
                      00026 
                      00027 #define BTN_SEL_LOCK BTN_LOCK,0   ; prevents repeat-fire while held
                      00028 #define BTN_ENT_LOCK BTN_LOCK,1
                      00029 #define BTN_BCK_LOCK BTN_LOCK,2
                      00030 
                      00031 ;  PROJECT: Multi-Mode Display System (PIC16F877A + Nokia 5110 LCD)
                      00032 ;  MODES:
                      00033 ;    0x00 - Clock       (HH:MM:SS with blinking separators)
                      00034 ;    0x01 - Stopwatch   (HH:MM:SS, Start/Stop via ENTER button)
                      00035 ;    0x02 - HSLM        (Scrolling horizontal marquee animation)
                      00036 ;    0xFF - Main Menu   (SELECT cycles items, ENTER opens, BACK returns)
                      00037 ;  HARDWARE:
                      00038 ;    LCD  -> PORTD (SPI via MSSP): RST=RD0, DC=RD1, CE=RD2
                      00039 ;    BTNs -> PORTB (active-low):   SEL=RB4, ENT=RB5, BCK=RB6
                      00040 ;    Timer0 ISR fires every ~1ms  (Prescaler 1:256, Fosc=4MHz)
                      00041 ;    77 ticks = ~1 second
                      00042 
0000                  00043     org 0x00
