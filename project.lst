                      00194    
006A   0823           00195    MOVF    SYSTEM_MODE, W
006B   3A01           00196    XORLW   0x01
006C   1903           00197    BTFSC   STATUS, Z
006D   21AB           00198    CALL    UpdateStopWatch ; refresh stopwatch display
006E   0008           00199    RETURN
                      00200    
                      00201 
                      00202 ;HSLM ANIMATION MATH : Fires every 8 ticks (not every second).
                      00203 ;Moves the HSLM sprite one pixel left; wraps at 0 back to column 48.
                      00204 ;Only draws when SYSTEM_MODE == 0x02 (HSLM screen is open).
006F                  00205 HSLM_MATH:
006F   0AB6           00206    INCF    HSLM_TICK, F
0070   3008           00207    MOVLW   d'8'
0071   0236           00208    SUBWF   HSLM_TICK, W
0072   1D03           00209    BTFSS   STATUS, Z
0073   0008           00210    RETURN                 ; not 8 ticks yet
                      00211 
0074   01B6           00212    CLRF    HSLM_TICK      ; reset sub-tick
                      00213    
0075   0823           00214    MOVF    SYSTEM_MODE, W ; only animate on HSLM screen
0076   3A02           00215    XORLW   0x02
0077   1D03           00216    BTFSS   STATUS, Z
0078   0008           00217    RETURN
                      00218 
0079   03B5           00219    DECF    HSLM_POS, F    ; move sprite left
007A   08B5           00220    MOVF    HSLM_POS, F    ; check if reached 0
007B   1D03           00221    BTFSS   STATUS, Z
007C   287F           00222    GOTO    HSLM_DRAW_NOW
007D   3030           00223    MOVLW   D'48'          ; wrap: reset to right edge
007E   00B5           00224    MOVWF   HSLM_POS
                      00225    
007F                  00226 HSLM_DRAW_NOW:
007F   218A           00227    CALL    DrawHSLMScreen
0080   0008           00228    RETURN
                      00229    
                      00230 ;CLOCK MATH(called every second)
                      00231 ;Increments SEC -> MIN -> HOUR with rollover (24-hour format).
                      00232 ;Also toggles COLON_STATE for blinking separators.
0081                  00233 CLOCK_MATH:
0081   3001           00234    MOVLW   0x01
0082   06B7           00235    XORWF   COLON_STATE, F       ; bonus: blink clock separators
                      00236    
0083   0AA8           00237    INCF    CLK_SEC, F
0084   303C           00238    MOVLW   d'60'
0085   0228           00239    SUBWF   CLK_SEC, W
0086   1D03           00240    BTFSS   STATUS, Z
0087   0008           00241    RETURN                       ; seconds not rolled over
                      00242    
0088   01A8           00243    CLRF    CLK_SEC
0089   0AA9           00244    INCF    CLK_MIN, F
                      00245 
008A   303C           00246    MOVLW   d'60'
