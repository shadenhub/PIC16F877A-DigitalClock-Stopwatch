                      00413 ;2.INPUT ROUTING --> (POLL_INTERFACES) 
                      00414 ;Priority: SELECT -> ENTER -> BACK
                      00415 ;SELECT: cycles CURRENT_MENU (only in main menu), redraws menu.
                      00416 ;ENTER:  opens the selected mode -OR- toggles stopwatch start/stop.
                      00417 ;BACK:   returns to main menu from any mode.  
00F8                  00418 POLL_INTERFACES:    
00F8   20DD           00419     CALL    CHECK_BUTTONS       ; read buttons and set BTN_SEL_FLG, BTN_ENT_FLG, BTN_BCK_FLG
                      00420     ;SELECT: cycle through menu items
00F9   1CA4           00421     BTFSS   BTN_SEL_FLG         ; was SELECT pressed this tick?       
00FA   2906           00422     GOTO    ROUTE_ENTER         ; no -> skip to ENTER check
00FB   10A4           00423     BCF     BTN_SEL_FLG         ; yes -> clear flag (acknowledge)
                      00424     
                      00425     ; SELECT only works when we are on the main menu (SYSTEM_MODE = 0xFF).
                      00426     ; If we're inside a mode screen, ignore SELECT completely.        
00FC   0823           00427     MOVF    SYSTEM_MODE, W      ; only cycle if on main menu   
00FD   3AFF           00428     XORLW   0xFF                ; XOR with 0xFF: result=0 only if SYSTEM_MODE=0xFF
00FE   1D03           00429     BTFSS   STATUS, Z           ; Z=1 -> we are on the menu
00FF   2906           00430     GOTO    ROUTE_ENTER         ; Z=0 -> inside a mode, ignore SELECT    
                      00431     
0100   0AA2           00432     INCF    CURRENT_MENU, F     ; move cursor to next menu item
0101   3003           00433     MOVLW   D'3'                
0102   0222           00434     SUBWF   CURRENT_MENU, W     ; check if we passed the last item (3 items: 0,1,2)
0103   1903           00435     BTFSC   STATUS, Z          
0104   01A2           00436     CLRF    CURRENT_MENU        ; Wrap back around to 0
0105   211B           00437     CALL    SHOW_MAIN_MENU      ; redraw menu with new selection highlighted 
                      00438    
                      00439     ;ENTER: open mode or toggle stopwatch
0106                  00440 ROUTE_ENTER:    
0106   1D24           00441     BTFSS   BTN_ENT_FLG         ; was ENTER pressed?  
0107   2912           00442     GOTO    ROUTE_BACK     
0108   1124           00443     BCF     BTN_ENT_FLG 
                      00444             
0109   0823           00445     MOVF    SYSTEM_MODE, W      
010A   3AFF           00446     XORLW   0xFF                ;  are we on the main menu?
010B   1D03           00447     BTFSS   STATUS, Z     
010C   29D8           00448     GOTO    STOPWATCH_TOGGLE    ; inside a mode -> ENTER = start/stop stopwatch
                      00449     
                      00450     ; On main menu: open the selected mode
010D   0822           00451     MOVF    CURRENT_MENU, W     ; CURRENT_MENU holds which item is selected (0/1/2)  
010E   00A3           00452     MOVWF   SYSTEM_MODE         ; set SYSTEM_MODE to that mode
010F   20CA           00453     CALL    CLEAR_SCREEN        
0110   2142           00454     CALL    OPEN_MODE_SCREEN    ; draw the mode's screen   
0111   2912           00455     GOTO    ROUTE_BACK
                      00456     
                      00457     ;BACK: return to main menu
0112                  00458 ROUTE_BACK:
