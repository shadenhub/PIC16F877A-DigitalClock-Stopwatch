LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00777 ;FONT UTILITIES:
                      00778 ;1.SPLIT_2DIGIT --> value (0-99).
                      00779 ;Returns: First_Digit = ones,  Second_Digit = tens.
                      00780 ;Algorithm: subtract 10 repeatedly.
                      00781 ;Example: value=47 -> subtract 10 four times -> First_Digit=7, Second_Digit=4
01EF                  00782 SPLIT_2DIGIT: 
01EF   00B2           00783     MOVWF First_Digit     ; store the full value in First_Digit
01F0   01B3           00784     CLRF  Second_Digit    ; tens counter starts at 0
01F1                  00785 SPLIT_LOOP:
01F1   300A           00786     MOVLW d'10'
01F2   0232           00787     SUBWF First_Digit, W  ; W = First_Digit - 10
01F3   1C03           00788     BTFSS STATUS, C       ; C=0 means borrow occurred (First_Digit < 10) -> done
01F4   29F8           00789     GOTO  SPLIT_DONE
01F5   00B2           00790     MOVWF First_Digit     ; C=1 means result is valid, store remainder
01F6   0AB3           00791     INCF  Second_Digit, F ; count one more ten
01F7   29F1           00792     GOTO  SPLIT_LOOP
01F8                  00793 SPLIT_DONE:
                      00794     ; Now: Second_Digit = tens place, First_Digit = ones place
01F8   0008           00795     RETURN
                      00796 
                      00797 
                      00798 ;2.Send_Font_Digit --> digit (0-9).
                      00799 ;Looks up 5 column bytes in FONT_Table and sends them via SEND_DATA.
                      00800 ;Index = digit * 5.
                      00801 ;PCLATH must be set to 0x05 for the ORG 0x500 table.    
01F9                  00802 Send_Font_Digit:
01F9   00B0           00803     MOVWF   Digit
01FA   00A0           00804     MOVWF   W_TEMP
01FB   1003           00805     BCF     STATUS, C            ; clear carry before shifting
01FC   0DA0           00806     RLF     W_TEMP, F            ; W_TEMP = Digit * 2
01FD   0DA0           00807     RLF     W_TEMP, F            ; W_TEMP = Digit * 4
01FE   0820           00808     MOVF    W_TEMP, W
01FF   0730           00809     ADDWF   Digit, W             ; W = Digit * 5
0200   00AF           00810     MOVWF   Index                ; Index now points to first byte of this digit in table
                      00811     
0201   3005           00812     MOVLW   0x05
0202   00A0           00813     MOVWF   W_TEMP               ; loop 5 times (one per column byte)
                      00814     
0203                  00815 D_LOOP_OLD:
0203   3005           00816     MOVLW   0x05                 ; page 5 for FONT_Table at ORG 0x500
0204   008A           00817     MOVWF   PCLATH
0205   082F           00818     MOVF    Index, W
0206   2500           00819     CALL    FONT_Table           ; returns one column byte in W via RETLW
0207   018A           00820     CLRF    PCLATH               ; restore PCLATH to page 0 (our code page)
0208   20B4           00821     CALL    SEND_DATA
0209   0AAF           00822     INCF    Index, F             ; advance to next byte 
020A   0BA0           00823     DECFSZ  W_TEMP, F            ; decrement loop counter, skip next if zero
020B   2A03           00824     GOTO    D_LOOP_OLD           ; not zero -> loop again 
020C   0008           00825     RETURN
                      00826     
                      00827     
                      00828 ;TEXT LABEL BITMAPS  (5x8 column-format, 6 bytes per character incl. space)
                      00829 ;Each PRINT_xxx routine sends the raw column data for its label text.
MPASM  5.51                       PROJECT.ASM   5-31-2026  23:11:30         PAGE 17


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00830 ;The Inverted versions XOR each byte with 0xFF for a highlight effect.    
                      00831 
                      00832 ;"CLOCK"
020D                  00833 PRINT_CLOCK_INVERTED:
                      00834     ; C
020D   303E           00835     MOVLW   0x3E
020E   20BF           00836     CALL    SEND_INV_DATA
